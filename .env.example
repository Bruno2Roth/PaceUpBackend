# Environment
NODE_ENV=development
PORT=3000

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=paceup_dev
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_MIN=2
DB_POOL_MAX=10

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=7d
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key
JWT_REFRESH_EXPIRATION=30d

# API Configuration
API_BASE_URL=http://localhost:3000
API_VERSION=v1
API_PAGINATION_LIMIT=20

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Rate Limiter
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=combined

# Redis (Future use)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cloudinary (Media uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Mapbox (GPS mapping)
MAPBOX_TOKEN=your_mapbox_token

# Garmin Integration
GARMIN_API_URL=https://connectapi.garmin.com
GARMIN_CLIENT_ID=your_garmin_client_id
GARMIN_CLIENT_SECRET=your_garmin_client_secret

# COROS Integration
COROS_API_URL=https://api.coros.com
COROS_API_KEY=your_coros_api_key

# Polar Integration
POLAR_API_URL=https://www.polaraccesslink.com
POLAR_CLIENT_ID=your_polar_client_id
POLAR_CLIENT_SECRET=your_polar_client_secret

# Suunto Integration
SUUNTO_API_URL=https://suunto-api.com
SUUNTO_API_KEY=your_suunto_api_key

# Apple Health Integration
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id

# Wear OS Integration
WEAROS_API_KEY=your_wearos_api_key

# Email Configuration (Future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Admin Configuration
ADMIN_EMAIL=admin@paceup.com
ADMIN_PASSWORD=change_me_in_production
